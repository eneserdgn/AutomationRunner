{
  "name": "pegasus-automation-runner",
  "version": "1.2.0",
  "description": "Pegasus Automation Runner – BDD Scenario Viewer & Runner",
  "author": {
    "name": "Enes Erdoğan"
  },
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "start": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && npm run electron-start\"",
    "dev": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && npm run electron-start\"",
    "react-start": "react-scripts start",
    "electron-start": "ELECTRON_START_URL=http://localhost:3000 electron .",
    "build": "react-scripts build && electron-builder",
    "publish": "react-scripts build && electron-builder --publish always",
    "react-build": "react-scripts build"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "jimp": "^1.6.1",
    "react-scripts": "5.0.1",
    "wait-on": "^7.2.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "build": {
    "appId": "com.pegasus.automationrunner",
    "productName": "Pegasus Automation Runner",
    "copyright": "© 2025 Enes Erdoğan",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "electron/**/*",
      "assets/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "identity": null,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Pegasus Automation Runner",
      "icon": "assets/icon.icns"
    },
    "publish": {
      "provider": "github",
      "owner": "eneserdgn",
      "repo": "AutomationRunner",
      "private": true
    }
  }
}
